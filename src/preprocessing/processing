    "/kaggle/input/competitions/"
    "vinbigdata-chest-xray-abnormalities-detection"
)
# DATA_ROOT 表示 VinBigData 数据集的主路径。


metadata_df = pd.read_csv(
    "/kaggle/working/dicom_metadata_all.csv"
)
# 读取之前生成的全部 DICOM 元数据 CSV。
# 读取后的表格保存到 metadata_df。


mono1_row = metadata_df[
    metadata_df["PhotometricInterpretation"] == "MONOCHROME1"
].iloc[0]
# 在 metadata_df 表格里筛选出
# PhotometricInterpretation 等于 MONOCHROME1 的行。
# .iloc[0] 表示取筛选结果中的第一行。


image_id = mono1_row["image_id"]
# 从这一行记录中取出 image_id。


split = mono1_row["split"]
# 从这一行记录中取出 split。
# split 表示图像属于 train 还是 test。


dicom_path = DATA_ROOT / split / f"{image_id}.dicom"
# 使用 DATA_ROOT、split 和 image_id 拼出完整的 DICOM 文件路径。
# 例如：
# 数据集主路径 / train / image_id.dicom


ds = pydicom.dcmread(dicom_path)
# 使用 pydicom 读取这张 DICOM 文件。
# 读取后的完整 DICOM 对象保存到 ds。


pixel_array = ds.pixel_array
# 从 DICOM 对象中提取图像像素矩阵。


if ds.PhotometricInterpretation == "MONOCHROME1":
    # 判断这张图像的光度解释方式是否为 MONOCHROME1。

    processed_pixel_array = (
        pixel_array.max()
        + pixel_array.min()
        - pixel_array
    )
    # 如果是 MONOCHROME1，就进行强度反转。

else:
    processed_pixel_array = pixel_array
    # 如果不是 MONOCHROME1，就不进行反转，保持原图。


print("image_id:", image_id)
# 打印图像 ID。

print("split:", split)
# 打印图像属于 train 还是 test。

print(
    "PhotometricInterpretation:",
    ds.PhotometricInterpretation
)
