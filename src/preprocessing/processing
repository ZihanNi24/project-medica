Ⅹ.处理全部图像，整体反转
# 遍历 train 和 test 的全部 DICOM。
# 每张都判断是否为 MONOCHROME1。
# 只有 MONOCHROME1 才进行强度反转。
# 已经保存过的文件自动跳过。
# 不显示每张图片。
# 持续处理到全部结束。


from pathlib import Path
# 从 pathlib 模块中导入 Path。
# Path 用来处理文件夹路径和文件路径。


import pydicom
# pydicom 用来读取 DICOM 医学影像文件。


import numpy as np
# numpy 用来处理图像像素矩阵和数值类型。


from PIL import Image
# 从 PIL 中导入 Image。
# Image 用来把处理后的像素矩阵保存成 PNG 图片。


from tqdm import tqdm
# tqdm 用来显示批量处理时的进度条。


DATA_ROOT = Path(
    "/kaggle/input/competitions/"
    "vinbigdata-chest-xray-abnormalities-detection"
)
# DATA_ROOT 是原始 VinBigData 数据集的主路径。


OUTPUT_ROOT = Path("/kaggle/working/monochrome1_processed")
# OUTPUT_ROOT 是处理后图片的总保存文件夹。
# 程序会在这个文件夹中继续建立 train 和 test 子文件夹。


processed_count = 0
# 记录本次新处理并保存的 MONOCHROME1 图像数量。


skipped_count = 0
# 记录因为输出文件已经存在而被跳过的图像数量。


mono2_count = 0
# 记录不是 MONOCHROME1，因此不需要反转的图像数量。


error_count = 0
# 记录处理失败的图像数量。


for split in ["train", "test"]:
    # 依次处理 train 和 test 两个文件夹。
    # 第一轮 split 是 "train"。
    # 第二轮 split 是 "test"。

    input_dir = DATA_ROOT / split
    # 拼出当前输入文件夹路径。
    # 例如 DATA_ROOT / "train"。

    output_dir = OUTPUT_ROOT / split
    # 拼出当前输出文件夹路径。
    # 例如 OUTPUT_ROOT / "train"。

    output_dir.mkdir(parents=True, exist_ok=True)
    # 创建当前输出文件夹。
    # parents=True 表示如果上级文件夹不存在，也一起创建。
    # exist_ok=True 表示文件夹已经存在时不报错。

    dicom_files = list(input_dir.glob("*.dicom"))
    # 找出当前输入文件夹下所有以 .dicom 结尾的文件。
    # list(...) 把找到的路径转换成列表。

    for dicom_path in tqdm(
        dicom_files,
        desc=f"Processing {split}"
    ):
        # 逐张遍历当前文件夹中的全部 DICOM 图像。
        # dicom_path 表示当前正在处理的 DICOM 文件路径。
        # tqdm 显示当前处理进度。

        try:
            # try 表示尝试执行下面的处理代码。
            # 如果某一张图像发生错误，程序不会整体停止，
            # 而是进入下面的 except，记录错误后继续处理下一张。

            ds = pydicom.dcmread(dicom_path)
            # 使用 pydicom 读取当前 DICOM 文件。
            # 完整的 DICOM 对象保存到 ds。

            if ds.PhotometricInterpretation != "MONOCHROME1":
                # 判断当前图像是否不是 MONOCHROME1。
                # != 表示“不等于”。

                mono2_count += 1
                # 如果不是 MONOCHROME1，
                # 就把不需要反转的数量加 1。

                continue
                # 跳过当前这张图，
                # 直接开始处理下一张 DICOM。

            image_id = dicom_path.stem
            # 获取当前图像的文件名，
            # 但不包含 .dicom 后缀。

            output_path = (
                output_dir
                / f"{image_id}_processed.png"
            )
            # 拼出处理后 PNG 图片的保存路径。
            # 例如：
            # /kaggle/working/monochrome1_processed/train/
            # 图像ID_processed.png

            if output_path.exists():
                # 检查这个输出文件是否已经存在。

                skipped_count += 1
                # 如果已经存在，
                # 就把跳过数量加 1。

                continue
                # 跳过当前这张图，
                # 不重复处理，也不覆盖已有文件。

            pixel_array = ds.pixel_array.astype(np.int32)
            # 从 DICOM 对象中提取图像像素矩阵。
            # astype(np.int32) 把像素数据转换成 int32。
            # 这样做可以避免反转计算时出现无符号整数问题。

            processed_pixel_array = (
                pixel_array.max()
                + pixel_array.min()
                - pixel_array
            )
            # 对 MONOCHROME1 图像进行强度反转。
            # 原本较大的像素值会变小，
            # 原本较小的像素值会变大。

            processed_pixel_array = (
                processed_pixel_array.astype(np.uint16)
            )
            # 把处理后的像素矩阵转换回 uint16。
            # uint16 适合保存原始高位深灰度图像。

            Image.fromarray(
                processed_pixel_array
            ).save(output_path)
            # 把处理后的像素矩阵转换成图片对象。
            # 然后保存到 output_path 指定的位置。

            processed_count += 1
            # 当前图像成功处理并保存后，
            # 把新处理数量加 1。

        except Exception as error:
            # 如果当前图像处理过程中发生错误，
            # 程序会进入这里，而不会整体停止。

            error_count += 1
            # 把处理失败数量加 1。

            print("处理失败：", dicom_path.name)
            # 打印处理失败的 DICOM 文件名。

            print("错误：", error)
            # 打印具体错误信息。


print("处理完成")
# 所有 train 和 test 图像遍历结束后，
# 打印处理完成。


print(
    "新处理的 MONOCHROME1 数量：",
    processed_count
)
# 打印本次新处理并保存的 MONOCHROME1 图像数量。


print(
    "已存在并跳过的数量：",
    skipped_count
)
# 打印因为输出文件已经存在而跳过的数量。


print(
    "不是 MONOCHROME1 的数量：",
    mono2_count
)
# 打印不是 MONOCHROME1、
# 因此没有进行反转的图像数量。


print(
    "处理失败数量：",
    error_count
)
